# ───────────────────────────────────────────────────────────────
# Marsad — environment template.  Copy to apps/web/.env.local and fill.
# Everything here is changeable later (brand name, project, tokens).
# NEXT_PUBLIC_* values are exposed to the browser (safe for keys that
# are public by design). Everything else stays server-side only.
# ───────────────────────────────────────────────────────────────

# ── Brand (public, edit freely — also overridable from admin panel) ──
NEXT_PUBLIC_BRAND_NAME=الشاهين

# ── Supabase (Phase 1) ──
# URL + publishable/anon key are public by design. Service role is SECRET.
NEXT_PUBLIC_SUPABASE_URL=https://your-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=                 # SECRET — dashboard > Settings > API. Needed Phase 3+ (services)

# ── OpenRouter (Phase 3 — AI pipeline) ──
OPENROUTER_API_KEY=

# ── Telegram review bot (Phase 5) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── Resend email (Phase 7) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=news@yourdomain.com

# ── Image generation (Phase 6) ──
REPLICATE_API_TOKEN=
FAL_KEY=

# ── Ingestion (Phase 2) ──
# Shared secret the scheduler (n8n/cron) sends as `x-ingest-secret` to /api/cron/ingest.
INGEST_SECRET=

# ── Sources (Phase 4) ──
GITHUB_TOKEN=
PRODUCTHUNT_TOKEN=

# ── Publishing extras (Phase 7) ──
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── Analytics & monitoring (Phase 9) ──
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
SENTRY_DSN=
